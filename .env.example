# Supabase - use TEST project for development/preview/play, PROD for production
EXPO_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_test_anon_key_here

# Environment indicator (test | prod) - shown in Settings
EXPO_PUBLIC_SUPABASE_ENV=test

# Optional: public invite RSVP smoke (npm run verify:invite-rsvp) against a real project with migration 121+
# VERIFY_INVITE_EVENT_ID=
# VERIFY_RESOLVE_EMAIL=
# VERIFY_RESOLVE_EXPECT=not_found|unlinked|linked|ambiguous

# App stage for rivalry share links: beta (Vercel web + /join-rivalry) | production (App Store / Play Store)
EXPO_PUBLIC_APP_STAGE=beta

# GolfCourseAPI - used by /api/golf/search (server-side). Also supports NEXT_PUBLIC_GOLF_API_KEY.
# Required for course search. Use "npm run dev:web" (not "npm run web") for local web dev so API routes work.
GOLF_API_KEY=your_golfcourseapi_key_here
# Optional: Expo client can read EXPO_PUBLIC_GOLF_API_KEY for direct API calls in dev builds.
# EXPO_PUBLIC_GOLF_API_KEY=

# OpenWeatherMap — primary in-app forecast when set (see lib/env getWeatherProviderId).
# Falls back to Open-Meteo when unset. On web, Open-Meteo is loaded via /api/weather/* (Vercel or dev-api-server on :3001).
# Use "npm run dev:web" for local web so weather + golf proxies both run.
EXPO_PUBLIC_WEATHER_API_KEY=
# EXPO_PUBLIC_WEATHER_PROVIDER=

# Course import priority + official source acquisition
# COURSE_IMPORT_PRIORITY_COURSES=The Vale Resort,Wycombe Heights Golf Centre,Upavon Golf Club,Shrivenham Park Golf Club
# COURSE_IMPORT_PRIORITY_COURSES_JSON=data/course-import-priority-courses.json
# COURSE_IMPORT_MANUAL_SCORECARD_JSON=data/manual-scorecards.json
